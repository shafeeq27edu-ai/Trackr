# ============================================================
# Development Environment Overrides (.env.dev)
# ============================================================
# Use this file when running the backend NATIVELY (not in Docker)
# so that it connects to DB and Redis on localhost instead of
# Docker service names.
#
# Usage: run_dev.ps1 automatically loads these values.
# ============================================================

# --- Infrastructure (pointing to Docker-exposed ports on localhost) ---
DATABASE_URL=postgresql+asyncpg://trackr_user:trackr_password@localhost:5432/trackr_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# --- Execution backend: use 'celery' to match Docker mode ---
EXECUTION_BACKEND=celery

# --- Everything below is inherited from .env, repeated for clarity ---
YOLO_MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.3
HARDWARE_ACCELERATION=auto
TEMP_DIR=data/temp
OUTPUT_DIR=outputs/api
LOG_DIR=outputs
LOG_LEVEL=INFO
LOG_FORMAT=json
SECRET_KEY=trackr-super-secret-development-key-change-in-production
API_BASE_URL=http://localhost:8000/api/v1
SYS_API_BASE_URL=http://localhost:8000/api/v1/system
